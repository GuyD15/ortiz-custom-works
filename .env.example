# ============================================================
# ORTIZ CUSTOM WORKS - BACKEND CONFIGURATION TEMPLATE
# ============================================================
# Copy this file to .env for local development.
# On Render, set the same keys in Dashboard > Environment.

# ============================================================
# SERVER / CORS / LOGGING
# ============================================================
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# Primary allowed frontend origin (required)
FRONTEND_URL=https://ortizcustomworks.com

# Optional additional allowed origins (comma-separated)
FRONTEND_URLS=https://www.ortizcustomworks.com

# ============================================================
# GOOGLE reCAPTCHA v3
# ============================================================
# IMPORTANT: this must be the SECRET key paired with site key:
# 6Leob4YsAAAAAIQMO2g103_fjPwHuyGjkSwlytDV
RECAPTCHA_SECRET_KEY=PASTE_RECAPTCHA_SECRET_KEY_HERE

# ============================================================
# EMAIL CONFIGURATION (contact form + notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
OWNER_EMAIL=ortizcustomworks@gmail.com

# ============================================================
# QUICKBOOKS CONFIGURATION (encrypted token mode)
# ============================================================
QB_CLIENT_ID=YOUR_CLIENT_ID_HERE
QB_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
QB_REALM_ID=YOUR_REALM_ID_HERE

# 64 hex characters required (32-byte key)
QB_ENCRYPTION_KEY=PASTE_64_HEX_CHAR_KEY_HERE

# Encrypted token values (iv:authTag:ciphertext)
QB_ACCESS_TOKEN_ENCRYPTED=PASTE_ENCRYPTED_ACCESS_TOKEN_HERE
QB_REFRESH_TOKEN_ENCRYPTED=PASTE_ENCRYPTED_REFRESH_TOKEN_HERE

# ============================================================
# OPTIONAL / LEGACY QB KEYS (for scripts/docs compatibility)
# ============================================================
QB_ACCESS_TOKEN=
QB_REFRESH_TOKEN=
QB_API_URL=https://quickbooks.api.intuit.com/v2/company
QB_AP_ACCOUNT_ID=2
