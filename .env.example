# ============================================================
# ORTIZ CUSTOM WORKS - BACKEND CONFIGURATION
# ============================================================
# 
# Copy this file as .env and fill in your actual values
# NEVER commit .env to Git - add it to .gitignore
#

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================================
# EMAIL CONFIGURATION (for contact form & payment confirmations)
# ============================================================
# Using Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Generate an App Password: myaccount.google.com/apppasswords
#   3. Use that 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password
OWNER_EMAIL=ortizcustomworks@gmail.com

# Or use any SMTP provider (SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=your-sendgrid-api-key

# ============================================================
# QUICKBOOKS CONFIGURATION
# ============================================================
# Get these from: https://developer.intuit.com
# Instructions in QUICKBOOKS_INTEGRATION_GUIDE.md

QB_CLIENT_ID=YOUR_CLIENT_ID_HERE
QB_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
QB_REALM_ID=YOUR_REALM_ID_HERE
QB_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
QB_REFRESH_TOKEN=YOUR_REFRESH_TOKEN_HERE
QB_API_URL=https://quickbooks.api.intuit.com/v2/company
QB_AP_ACCOUNT_ID=2

# ============================================================
# EXAMPLE VALUES (for reference only - replace with real values)
# ============================================================
# 
# QB_REALM_ID=1234567890
# QB_CLIENT_ID=ABCDEf0ghijklmnopqrstuvwxyzABC123
# QB_ACCESS_TOKEN=eyJhbGciOiJSUzI1NiIsImtpZCI6InNvbWU...
#
